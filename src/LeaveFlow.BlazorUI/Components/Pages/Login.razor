@page "/login"
@layout EmptyLayout
@inject ApiService Api
@inject AuthService Auth
@inject NavigationManager Nav
@using LeaveFlow.BlazorUI.Services
@using LeaveFlow.Application.DTOs

<div class="lf-login-page">
    <div class="lf-login-card">
        <div class="lf-login-logo">
            <h1>🌊 LeaveFlow</h1>
            <p>Enterprise HR Leave Management</p>
        </div>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="lf-alert lf-alert-error">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:16px;height:16px;flex-shrink:0"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                @_error
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />
            <div class="lf-form-group">
                <label class="lf-label">Email Address</label>
                <input class="lf-input @(_error != null ? "lf-input-error" : "")"
                       type="email" placeholder="you@company.com"
                       @bind="_model.Email" />
            </div>
            <div class="lf-form-group">
                <label class="lf-label">Password</label>
                <input class="lf-input @(_error != null ? "lf-input-error" : "")"
                       type="password" placeholder="••••••••"
                       @bind="_model.Password" />
            </div>
            <button class="btn btn-primary" style="width:100%;justify-content:center;padding:11px;" type="submit" disabled="@_loading">
                @if (_loading)
                {
                    <span>Signing in…</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </button>
        </EditForm>

        <p style="text-align:center;margin-top:20px;font-size:12px;color:var(--gray-400)">
            LeaveFlow Enterprise v1.0 · Secure Login
        </p>
    </div>
</div>

@code {
    class LoginForm { public string Email { get; set; } = ""; public string Password { get; set; } = ""; }
    readonly LoginForm _model = new();
    bool _loading;
    string? _error;

    protected override async Task OnAfterRenderAsync(bool first)
    {
        if (first && await Auth.IsAuthenticatedAsync())
            Nav.NavigateTo("/");
    }

    async Task HandleLogin()
    {
        _loading = true; _error = null;
        var result = await Api.LoginAsync(new LoginRequest(_model.Email, _model.Password));
        if (result is not null)
        {
            await Auth.LoginAsync(result);
            Nav.NavigateTo("/");
        }
        else
        {
            _error = "Invalid email or password. Please try again.";
        }
        _loading = false;
    }
}
