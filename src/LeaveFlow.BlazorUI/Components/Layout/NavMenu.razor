@inject NavigationManager Nav
@using LeaveFlow.BlazorUI.Services
@inject AuthService Auth

<div class="lf-sidebar">
    <div class="lf-sidebar-brand">
        <h1>🌊 LeaveFlow</h1>
        <span>Enterprise HR Platform</span>
    </div>

    <nav class="lf-nav">
        <div class="lf-nav-section">Main</div>
        <a class="lf-nav-item @Active("/")" href="/">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Dashboard
        </a>
        <a class="lf-nav-item @Active("/my-leaves")" href="/my-leaves">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            My Leaves
        </a>
        <a class="lf-nav-item @Active("/create-leave")" href="/create-leave">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
            Request Leave
        </a>

        @if (Role is "Manager" or "Admin")
        {
            <div class="lf-nav-section">Team</div>
            <a class="lf-nav-item @Active("/approvals")" href="/approvals">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Approvals
            </a>
        }

        @if (Role == "Admin")
        {
            <div class="lf-nav-section">Administration</div>
            <a class="lf-nav-item @Active("/admin/users")" href="/admin/users">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                Users
            </a>
            <a class="lf-nav-item @Active("/admin/audit-logs")" href="/admin/audit-logs">
                <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                Audit Logs
            </a>
        }

        <div class="lf-nav-section">Account</div>
        <a class="lf-nav-item @Active("/profile")" href="/profile">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Profile
        </a>
    </nav>

    <div class="lf-sidebar-footer">
        <button class="lf-logout-btn" @onclick="LogoutAsync">
            <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" style="width:16px;height:16px"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Logout
        </button>
    </div>
</div>

@code {
    [Parameter] public string Role { get; set; } = "Employee";

    string Active(string path) =>
        Nav.Uri.EndsWith(path) || (path != "/" && Nav.Uri.Contains(path)) ? "active" : "";

    async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/login");
    }
}
